package org.example.courework3.service;

import lombok.RequiredArgsConstructor;
import org.example.courework3.dto.BookingListResponse;
import org.example.courework3.dto.BookingResponse;
import org.example.courework3.dto.CreateBookingRequest;
import org.example.courework3.entity.Booking;
import org.example.courework3.entity.BookingHistory;
import org.example.courework3.entity.Role;
import org.example.courework3.entity.Slot;
import org.example.courework3.entity.Specialist;
import org.example.courework3.entity.User;
import org.example.courework3.repository.BookingHistoryRepository;
import org.example.courework3.repository.BookingRepository;
import org.example.courework3.repository.SlotRepository;
import org.example.courework3.repository.SpecialistRepository;
import org.example.courework3.repository.UserRepository;
import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;

import java.util.List;
import java.util.Map;
import java.util.Objects;

@Service
@RequiredArgsConstructor
public class BookingService {

    private final BookingRepository bookingRepository;
    private final BookingHistoryRepository bookingHistoryRepository;
    private final SlotRepository slotRepository;
    private final SpecialistRepository specialistRepository;
    private final UserRepository userRepository;

    public List<Booking> listBookings(Map<String, Object> params) {
        List<Booking> bookings = bookingRepository.findAll();
        return bookings;
    }

    public BookingListResponse listCustomerBookings(String customerId, String status) {
        List<BookingResponse> items = bookingRepository.findByCustomerIdOrderByCreatedAtDesc(customerId).stream()
                .filter(booking -> status == null || status.isBlank() || status.equals(booking.getStatus()))
                .map(this::toBookingResponse)
                .toList();
        return BookingListResponse.builder()
                .items(items)
                .total(items.size())
                .build();
    }

    public Booking getBooking(String id) {
        return bookingRepository.findById(id)
                .orElseThrow(() -> new RuntimeException("Booking not found: " + id));
    }

    public BookingResponse getBookingDetailForUser(String bookingId, User currentUser) {
        Booking booking = getBooking(bookingId);
        validateCustomerOrAdminAccess(booking, currentUser);
        return toBookingResponse(booking);
    }

    public Booking getBookingOrNull(String id) {
        return bookingRepository.findById(id).orElse(null);
    }

    @Transactional
    public Booking createBooking(CreateBookingRequest request, String customerId) {
        String specialistId = request.getSpecialistId();
        String slotId = request.getSlotId();
        String note = request.getNote();

        if (specialistId == null || specialistId.isBlank()) {
            throw new RuntimeException("Specialist ID cannot be empty");
        }
        if (slotId == null || slotId.isBlank()) {
            throw new RuntimeException("Slot ID cannot be empty");
        }
        if (customerId == null || customerId.isBlank()) {
            throw new RuntimeException("Customer ID cannot be empty");
        }
        if (!specialistRepository.existsById(specialistId)) {
            throw new RuntimeException("Specialist not found: " + specialistId);
        }
        if (!slotRepository.existsById(slotId)) {
            throw new RuntimeException("Slot not found: " + slotId);
        }
        if (!userRepository.existsById(customerId)) {
            throw new RuntimeException("Customer not found: " + customerId);
        }

        Slot slot = slotRepository.findById(slotId)
                .orElseThrow(() -> new RuntimeException("Slot not found"));
        if (!Boolean.TRUE.equals(slot.getAvailable())) {
            throw new RuntimeException("Slot is not available");
        }
        if (!slot.getSpecialistId().equals(specialistId)) {
            throw new RuntimeException("Slot does not belong to the specified specialist");
        }

        Booking booking = new Booking();
        booking.setCustomerId(customerId);
        booking.setSpecialistId(specialistId);
        booking.setSlotId(slotId);
        booking.setNote(note);
        booking.setStatus("Pending");

        Booking saved = bookingRepository.save(booking);

        slot.setAvailable(false);
        slotRepository.save(slot);

        BookingHistory history = new BookingHistory();
        history.setBookingId(saved.getId());
        history.setStatus("Pending");
        bookingHistoryRepository.save(history);

        return saved;
    }

    @Transactional
    public Booking updateBookingStatus(String id, String status, String reason) {
        Booking booking = bookingRepository.findById(id)
                .orElseThrow(() -> new RuntimeException("Booking not found: " + id));

        booking.setStatus(status);
        Booking saved = bookingRepository.save(booking);

        BookingHistory history = new BookingHistory();
        history.setBookingId(id);
        history.setStatus(status);
        history.setReason(reason);
        bookingHistoryRepository.save(history);

        if ("Cancelled".equals(status) || "Rejected".equals(status)) {
            Slot slot = slotRepository.findById(booking.getSlotId()).orElse(null);
            if (slot != null) {
                slot.setAvailable(true);
                slotRepository.save(slot);
            }
        }

        return saved;
    }

    @Transactional
    public Booking cancelBooking(String bookingId, User currentUser, String reason) {
        Booking booking = getBooking(bookingId);
        validateCustomerOrAdminAccess(booking, currentUser);
        return updateBookingStatus(bookingId, "Cancelled", reason);
    }

    @Transactional
    public Booking rescheduleBooking(String bookingId, User currentUser, String newSlotId) {
        Booking booking = getBooking(bookingId);
        validateCustomerOrAdminAccess(booking, currentUser);

        if (newSlotId == null || newSlotId.isBlank()) {
            throw new RuntimeException("slotId is required");
        }

        Slot newSlot = slotRepository.findById(newSlotId)
                .orElseThrow(() -> new RuntimeException("Slot not found"));
        if (!Boolean.TRUE.equals(newSlot.getAvailable())) {
            throw new RuntimeException("Slot is not available");
        }
        if (!Objects.equals(newSlot.getSpecialistId(), booking.getSpecialistId())) {
            throw new RuntimeException("Slot does not belong to the booking specialist");
        }

        Slot oldSlot = slotRepository.findById(booking.getSlotId()).orElse(null);
        if (oldSlot != null) {
            oldSlot.setAvailable(true);
            slotRepository.save(oldSlot);
        }

        booking.setSlotId(newSlotId);
        booking.setStatus("Rescheduled");
        Booking updated = bookingRepository.save(booking);

        newSlot.setAvailable(false);
        slotRepository.save(newSlot);

        BookingHistory history = new BookingHistory();
        history.setBookingId(updated.getId());
        history.setStatus("Rescheduled");
        bookingHistoryRepository.save(history);

        return updated;
    }

    public List<BookingHistory> getBookingHistory(String bookingId) {
        return bookingHistoryRepository.findByBookingIdOrderByChangedAtDesc(bookingId);
    }

    public BookingResponse toBookingResponse(Booking booking) {
        String specialistName = specialistRepository.findById(booking.getSpecialistId())
                .map(Specialist::getName)
                .orElse("");

        String timeStr = slotRepository.findById(booking.getSlotId())
                .map(Slot::getStartTime)
                .map(Object::toString)
                .orElse("");

        return BookingResponse.builder()
                .id(defaultString(booking.getId()))
                .customerId(defaultString(booking.getCustomerId()))
                .specialistId(defaultString(booking.getSpecialistId()))
                .specialistName(specialistName)
                .slotId(defaultString(booking.getSlotId()))
                .time(timeStr)
                .startTime(timeStr)
                .note(defaultString(booking.getNote()))
                .status(defaultString(booking.getStatus()))
                .createdAt(booking.getCreatedAt() != null ? booking.getCreatedAt().toString() : "")
                .updatedAt(booking.getUpdatedAt() != null ? booking.getUpdatedAt().toString() : "")
                .build();
    }

    private void validateCustomerOrAdminAccess(Booking booking, User currentUser) {
        if (currentUser == null) {
            throw new RuntimeException("Current user not found");
        }
        if (!Objects.equals(booking.getCustomerId(), currentUser.getId()) && currentUser.getRole() != Role.Admin) {
            throw new RuntimeException("Not your booking");
        }
    }

    private String defaultString(String value) {
        return value != null ? value : "";
    }
}
